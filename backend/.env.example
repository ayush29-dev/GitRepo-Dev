# ─────────────────────────────────────────────
# GROQ (free at console.groq.com → API Keys)
# ─────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ─────────────────────────────────────────────
# MYSQL (your local MySQL credentials)
# DB_NAME must exist — run: CREATE DATABASE gitrepo_dev;
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gitrepo_dev
DB_USER=root
DB_PASS=yourpassword

# ─────────────────────────────────────────────
# AWS S3 (for uploading generated READMEs/docs)
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
S3_BUCKET=gitrepo-dev-reports

# ─────────────────────────────────────────────
# GITHUB TOKEN (github.com/settings/tokens → classic → repo scope)
# ─────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
