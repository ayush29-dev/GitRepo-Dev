{
  "manifest_version": 3,
  "name": "GitRepo-Dev",
  "version": "1.0.0",
  "description": "AI-powered GitHub repo analysis — bug detection, code explanation, README generation.",

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "sidebar.js", "sidebar.css", "icons/*"],
      "matches": ["https://github.com/*"]
    }
  ]
}
